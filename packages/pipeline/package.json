{
  "name": "@cslate/pipeline",
  "version": "0.0.1",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@cslate/db": "workspace:*",
    "@cslate/llm": "workspace:*",
    "@cslate/queue": "workspace:*",
    "@cslate/storage": "workspace:*",
    "@typescript-eslint/typescript-estree": "^8.58.0",
    "drizzle-orm": "^0.40.0",
    "typescript": "^5.7.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.3.0",
    "vitest": "^2.1.0"
  }
}
