# ============================================================
# CSlate-Server — Local Development Environment
# Copy to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.
# ============================================================

# --- Database (Docker: docker compose up) ---
DATABASE_URL=postgresql://cslate:cslate@localhost:5432/cslate_dev
DATABASE_URL_DIRECT=postgresql://cslate:cslate@localhost:5432/cslate_dev

# --- Object Storage (MinIO — local R2 replacement) ---
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=cslate-dev
R2_ENDPOINT=http://localhost:9000
# MinIO web UI: http://localhost:9001 (minioadmin / minioadmin)

# ─── LLM — choose ONE mode ───────────────────────────────────────────────────

# Mode A: Gateway (recommended)
#   One URL + one key routes all providers (Anthropic, OpenAI, Alibaba, etc.)
#   Get your gateway at https://vercel.com/dashboard/ai-gateway
#
# AI_GATEWAY_URL=https://ai-gateway.vercel.sh/v1
# AI_GATEWAY_KEY=vgw-...

# Mode B: Direct provider keys
#   Comment out AI_GATEWAY_URL/AI_GATEWAY_KEY and set keys per provider.
#
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
#
# Optional: custom embedding provider (DashScope, OpenRouter, etc.)
# Leave unset to use OPENAI_API_KEY for embeddings.
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_API_KEY=sk-...

# ─── LLM Models ──────────────────────────────────────────────────────────────

# Strong model — quality review, judge, security expert
LLM_QUALITY_MODEL=claude-opus-4-6

# Medium model — cataloging, standards, red-team
LLM_CATALOG_MODEL=claude-sonnet-4-6

# Embedding model
# Gateway:  alibaba/qwen3-embedding-4b  (or any model the gateway supports)
# Direct:   text-embedding-3-small       (OpenAI default)
EMBEDDING_MODEL=text-embedding-3-small

# ─── Email (MailHog — local SMTP) ────────────────────────────────────────────
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@cslate.local
# View sent emails: http://localhost:8025

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# ─── Admin ───────────────────────────────────────────────────────────────────
# Required for /api/v1/admin/* endpoints. Generate with: openssl rand -hex 32
ADMIN_API_KEY=

# ─── Dev-only flags ──────────────────────────────────────────────────────────
DEV_SKIP_EMAIL_VERIFY=true
# When true: POST /api/v1/auth/register returns apiKey immediately (skips email flow)

DEV_SEED_API_KEY=cslate_dev_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# Pre-seeded by `pnpm db:seed`. Use in CSlate client as VITE_DEV_API_KEY.
