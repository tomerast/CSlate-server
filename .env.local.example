# ============================================================
# CSlate-Server — Local Development Environment
# Copy to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.
# ============================================================

# --- Database (Docker: docker compose up) ---
DATABASE_URL=postgresql://cslate:cslate@localhost:5432/cslate_dev
DATABASE_URL_DIRECT=postgresql://cslate:cslate@localhost:5432/cslate_dev
# Use DATABASE_URL for app connections (pg pool)
# Use DATABASE_URL_DIRECT for drizzle-kit migrations only

# --- Object Storage (MinIO — local R2 replacement) ---
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=cslate-dev
R2_ENDPOINT=http://localhost:9000
# MinIO web UI: http://localhost:9001 (minioadmin / minioadmin)

# --- LLM: Anthropic (real API — no mocking) ---
ANTHROPIC_API_KEY=sk-ant-...
LLM_QUALITY_MODEL=claude-sonnet-4-6
LLM_CATALOG_MODEL=claude-haiku-4-5-20251001

# --- LLM: OpenAI (embeddings only) ---
OPENAI_API_KEY=sk-...
EMBEDDING_MODEL=text-embedding-3-small

# --- Email (MailHog — local SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@cslate.local
# View sent emails: http://localhost:8025

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- Dev-only flags ---
DEV_SKIP_EMAIL_VERIFY=true
# When true: POST /api/v1/auth/register returns apiKey immediately (skips email flow)
# Set to false to test the full email verification flow via MailHog

DEV_SEED_API_KEY=cslate_dev_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# The API key pre-seeded by `pnpm db:seed`. Use this in the CSlate client's
# .env.development as VITE_DEV_API_KEY for instant auth without registration.
