# ============================================================
# CSlate-Server — Local Development Environment
# Copy to .env.local and fill in your values.
# .env.local is gitignored — never commit real keys.
# ============================================================

# --- Database (Docker: docker compose up) ---
DATABASE_URL=postgresql://cslate:cslate@localhost:5432/cslate_dev
DATABASE_URL_DIRECT=postgresql://cslate:cslate@localhost:5432/cslate_dev
# Use DATABASE_URL for app connections (pg pool)
# Use DATABASE_URL_DIRECT for drizzle-kit migrations only

# --- Object Storage (MinIO — local R2 replacement) ---
R2_ACCOUNT_ID=local
R2_ACCESS_KEY_ID=minioadmin
R2_SECRET_ACCESS_KEY=minioadmin
R2_BUCKET_NAME=cslate-dev
R2_ENDPOINT=http://localhost:9000
# MinIO web UI: http://localhost:9001 (minioadmin / minioadmin)

# --- LLM: Anthropic (real API — no mocking) ---
ANTHROPIC_API_KEY=sk-ant-...
LLM_QUALITY_MODEL=claude-sonnet-4-6
LLM_CATALOG_MODEL=claude-haiku-4-5-20251001

# --- LLM: OpenAI (embeddings only) ---
OPENAI_API_KEY=sk-...

# --- Embeddings ---
# Default: OpenAI text-embedding-3-small (uses OPENAI_API_KEY above)
EMBEDDING_MODEL=text-embedding-3-small
#
# To use Qwen3 via DashScope (Alibaba Cloud):
#   Get API key at https://dashscope.console.aliyun.com/
# EMBEDDING_MODEL=qwen3-embedding-4b
# EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# EMBEDDING_API_KEY=sk-...
#
# To use Qwen3 via OpenRouter:
# EMBEDDING_MODEL=alibaba/qwen3-embedding-4b
# EMBEDDING_BASE_URL=https://openrouter.ai/api/v1
# EMBEDDING_API_KEY=sk-or-...

# --- LLM Gateway (optional — choose one approach) ---
#
# Option A: Vercel AI Gateway
#   Routes both Anthropic and OpenAI through Vercel's unified gateway.
#   Appends /anthropic or /openai to the base URL automatically.
#   Get your gateway URL from https://vercel.com/dashboard/ai-gateway
#
# AI_GATEWAY_URL=https://gateway.ai.vercel.app/v1/<team-id>/<gateway-name>
#
# Option B: Vertex AI (Anthropic on Google Cloud)
#   Use Google's Vertex AI API endpoint directly as a base URL override.
#   Requires a reverse proxy or Anthropic's Vertex-compatible endpoint.
#   See: https://cloud.google.com/vertex-ai/docs/generative-ai/claude
#
# ANTHROPIC_BASE_URL=https://us-east5-aiplatform.googleapis.com/v1/projects/<project>/locations/us-east5/publishers/anthropic/models
#
# Option C: OpenRouter (OpenAI-compatible gateway for all providers)
#   Routes OpenAI calls through OpenRouter (supports many models).
#
# OPENAI_BASE_URL=https://openrouter.ai/api/v1
# OPENAI_API_KEY=sk-or-...  # OpenRouter API key

# --- Email (MailHog — local SMTP) ---
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@cslate.local
# View sent emails: http://localhost:8025

# --- Server ---
PORT=3000
NODE_ENV=development
LOG_LEVEL=debug

# --- Dev-only flags ---
DEV_SKIP_EMAIL_VERIFY=true
# When true: POST /api/v1/auth/register returns apiKey immediately (skips email flow)
# Set to false to test the full email verification flow via MailHog

DEV_SEED_API_KEY=cslate_dev_aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa
# The API key pre-seeded by `pnpm db:seed`. Use this in the CSlate client's
# .env.development as VITE_DEV_API_KEY for instant auth without registration.
